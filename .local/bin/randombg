#!/bin/sh

show_help() {
  echo "usage: randombg [-h] [-w PATH_TO_WALLPAPER_DIRECTORY]"
  echo "                     [-f WALLPAPER_PERSISTENCE_FILE]"
  echo "                     [-d DISPLAY]"
  echo "                     [-r RESOLUTION]"
  echo "                     [-m MANUAL_WALLPAPER_FILE (has to be in walls dir)]"
  echo "Depends on set-wallpaper"
  echo "https://github.com/mjkillough/set-wallpaper"
}




disp=$DISPLAY
wall_path="$XDG_CONFIG_HOME/wall"
wall_pers_file="$XDG_CONFIG_HOME/wall.jpg"
resolution="none"
while getopts ":hw:f:r:d:m:" opt; do
  case $opt in
    d)
      disp=$OPTARG
      ;;
    w)
      wall_path=$OPTARG
      ;;
    f)
      wall_pers_file=$OPTARG
      ;;
    r)
      resolution=$OPTARG
      ;;
    h)
      show_help
      exit
      ;;
    m)
      tmp_pic=$OPTARG
  esac
done


cur=`cat $wall_path/current`
if [ "$tmp_pic" == "" ]
then
  pic=`ls $wall_path/walls | sed "/$cur/d" | shuf -n 1`
else
  pic="$tmp_pic"
fi

if [ $resolution == "none" ]
then
  DISPLAY=$disp resolution=`xdpyinfo | awk '/dimensions/{print $2}'`
fi
echo "$pic" > $wall_path/current
convert -resize "$resolution" $wall_path/walls/$pic $wall_pers_file
DISPLAY=$disp set-wallpaper --fade-secs 1 --image "$wall_pers_file"
DISPLAY=$disp wal -i "$wall_path/walls/$pic"
