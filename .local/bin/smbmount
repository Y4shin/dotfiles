#!/bin/sh

#Script to mount

show_help() {
  echo "usage: smbmount [-h] [-p prefix for credentials retreived from pass"
  echo "                         default=smb, prefix{_name,_pass}]"
  echo "                     [-d mount directory]"
  echo "                     [-s smb address/share]"
}
#parsing commandline args
while getopts hp:d:s: opt
do
  case $opt in
    h) show_help;exit 0;;
    p) PREFIX=$OPTARG;;
    d) MOUNTDIR=$OPTARG;;
    s) SHARE=$OPTARG;;
  esac
done

#asking for information not given in commandline args
if [ -z "$PREFIX" ]
then
  PASSMODE=`printf "pass\\nmanual"| dmenu -p "Use pass prefix or enter credentials manually?" -r`
  if [ "$PASSMODE" == "pass" ]
  then
    echo "1"
    PREFIX=`echo "" | dmenu -p "Pass prefix (prefix{_name,_pass}):"`
    PASS=`pass "$PREFIX"_pass`
    USERNAME=`pass "$PREFIX"_name`
  elif [ "$PASSMODE" == "manual" ]
  then
    echo "2"
    USERNAME=`echo "" | dmenu -p "Username:"`
    PASS=`echo "" | dmenu -p "Password:" -P`
  fi
fi

if [ -z "$MOUNTDIR" ]
then
  MOUNTDIR=`printf "~/mnt\\n/mnt" | dmenu -p "Mount directory:"`;
fi

if [ -z "$SHARE" ]
then
  SHARE=`echo "" | dmenu -p "Full share address:"`
fi


MNT_UID=`id -u`
MNT_GID=`id -g`
sudo -A mount -t cifs -o username=$USERNAME,password="$PASS",uid=$MNT_UID,gid=$MNT_GID $SHARE $MOUNTDIR
